# Copy to .env and fill in from your Supabase project:
#   Dashboard -> Project Settings -> Data API  (URL)
#   Dashboard -> Project Settings -> API Keys  (anon / publishable key)
#
# EXPO_PUBLIC_ vars are inlined into the JS bundle and are therefore public.
# Only ever put the anon/publishable key here -- never the service_role key.
# Row-level security is what protects the data; the anon key alone grants nothing.
#
# Leave these unset to run the app fully offline (local storage, no sign-in).

EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
