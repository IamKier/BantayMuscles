{
  "expo": {
    "name": "BantayMuscles",
    "slug": "BantayMuscles",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/bm-icon.png",
    "scheme": "bantaymuscles",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/bm-icon.png",
      "bundleIdentifier": "com.bantaymuscles.app"
    },
    "android": {
      "package": "com.bantaymuscles.app",
      "softwareKeyboardLayoutMode": "pan",
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACTIVITY_RECOGNITION"
      ],
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E4E2DD",
        "foregroundImage": "./assets/images/bm-adaptive.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/bm-favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#E4E2DD",
          "image": "./assets/images/bm-splash.png",
          "imageWidth": 240,
          "dark": {
            "backgroundColor": "#E4E2DD"
          }
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "BantayMuscles uses the camera to scan food barcodes."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8aee7bd6-0799-4b00-a217-aace6a65aa44"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/8aee7bd6-0799-4b00-a217-aace6a65aa44"
    }
  }
}
