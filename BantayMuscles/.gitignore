# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Built APKs / app bundles for distribution — artifacts, not source.
/dist/

# Local secrets — real Supabase values live here (see remote_config.example.dart)
/lib/remote_config.dart
# Gemini API key for in-app AI logging (see ai_config.example.dart)
/lib/ai_config.dart

# Release signing — NEVER commit the keystore or its passwords. Back them up
# somewhere safe: losing them means you can't ship updates to the same app.
/android/key.properties
**/*.jks
**/*.keystore

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release
